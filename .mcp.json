{
  "mcpServers": {
    "git": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "env": {}
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "POSTGRES_CONNECTION_STRING": "postgresql://postgres:postgres@localhost:5432/clinic"
      }
    },
    "fetch": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "env": {}
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {}
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ofir/Documents/Clinic-app"
      ],
      "env": {}
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"],
      "env": {},
      "disabled": false,
      "alwaysAllow": [
        "list_pages",
        "select_page",
        "new_page",
        "close_page",
        "navigate_page",
        "take_snapshot",
        "take_screenshot",
        "click",
        "fill",
        "fill_form",
        "hover",
        "press_key",
        "wait_for",
        "list_console_messages",
        "get_console_message",
        "list_network_requests",
        "get_network_request",
        "evaluate_script",
        "resize_page",
        "handle_dialog",
        "upload_file",
        "drag",
        "emulate",
        "performance_start_trace",
        "performance_stop_trace",
        "performance_analyze_insight"
      ]
    }
  }
}
