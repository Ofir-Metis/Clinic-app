# Clinic App Backup Configuration
# Copy this file to .env.backup and adjust values for your environment
# Usage: source scripts/.env.backup && ./scripts/backup.sh

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinic

# Backup Directories
BACKUP_DIR=/backups/postgres
MINIO_BACKUP_DIR=/backups/minio

# MinIO Configuration (optional - skipped if mc not installed)
MINIO_ALIAS=minio
MINIO_BUCKET=clinic-storage

# Skip MinIO backup (set to true to disable)
# SKIP_MINIO_BACKUP=false

# Retention Policy (hardcoded in script, documented here)
# DAILY_RETENTION=7
# WEEKLY_RETENTION=4
# MONTHLY_RETENTION=3
