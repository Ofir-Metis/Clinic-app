# Production Environment Variables for Clinic Platform
# Self-development coaching platform for personal growth coaches

# Database Configuration
POSTGRES_PASSWORD=clinic_prod_secure_2024
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clinic_production
POSTGRES_USER=postgres

# Redis Configuration
REDIS_PASSWORD=clinic_redis_secure_prod
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Security (Enterprise Configuration)
JWT_SECRET=clinic_jwt_production_ultra_secure_secret_key_2024_very_long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=clinic-platform
JWT_AUDIENCE=clinic-users
JWT_MAX_AGE=24h
JWT_ALGORITHM=HS256

# MinIO/S3 Storage
MINIO_ROOT_USER=clinic_minio_admin
MINIO_ROOT_PASSWORD=clinic_minio_secure_password_2024
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=clinic_minio_admin
MINIO_SECRET_KEY=clinic_minio_secure_password_2024

# External Services (Configure for production)
OPENAI_API_KEY=sk-your-openai-api-key-here
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number
SENDGRID_API_KEY=your-sendgrid-api-key

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google Integration (Temporary values for Docker Compose)
GOOGLE_CLIENT_ID=temp_google_client_id_placeholder
GOOGLE_CLIENT_SECRET=temp_google_client_secret_placeholder
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
GOOGLE_CALENDAR_CLIENT_ID=temp_google_calendar_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=temp_google_calendar_client_secret
TOKEN_ENCRYPTION_KEY=temp_token_encryption_key_32_chars_

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Israeli Payment Providers
TRANZILLA_TERMINAL=your-tranzilla-terminal
TRANZILLA_USER=your-tranzilla-user
CARDCOM_CLIENT_ID=your-cardcom-client-id
CARDCOM_CLIENT_SECRET=your-cardcom-client-secret

# AWS/CloudFront Configuration (Temporary values for Docker Compose)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_REGION=us-east-1
S3_BUCKET_NAME=clinic-s3-bucket
S3_ENDPOINT=http://minio:9000
CLOUDFRONT_DISTRIBUTION_ID=temp_cloudfront_distribution_id
CLOUDFRONT_DOMAIN=temp-cloudfront.example.com

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# NATS Configuration
NATS_URL=nats://nats:4222

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info
ENVIRONMENT=production
