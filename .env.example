# PostgreSQL server host (Docker service name)
POSTGRES_HOST=postgres

# PostgreSQL server port
POSTGRES_PORT=5432

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password
POSTGRES_PASSWORD=postgres

# Name of the database
POSTGRES_DB=clinic

# Secret used for signing JWT tokens
JWT_SECRET=change-me

# NATS message broker URL
NATS_URL=nats://localhost:4222

# Endpoint for S3 or MinIO storage
S3_ENDPOINT=http://localhost:9000
# S3/MinIO access key (create in your storage provider)
S3_ACCESS_KEY=your-access-key
# S3/MinIO secret key (create in your storage provider)
S3_SECRET_KEY=your-secret-key

# Allowed CORS origin for backend APIs
FRONTEND_ORIGIN=http://localhost:5173
# Base URL of the API gateway
API_URL=http://localhost:3000

# Google OAuth client ID for the frontend
VITE_GOOGLE_CLIENT_ID=your-google-client-id
# Google OAuth client ID for the backend
GOOGLE_CLIENT_ID=your-google-client-id

# Email account username for SMTP (used for password resets)
EMAIL_USER=your-email@example.com
# Email account password for SMTP (used for password resets)
EMAIL_PASS=your-email-password

# Twilio account SID from the Twilio dashboard (WhatsApp messages)
TWILIO_ACCOUNT_SID=your-twilio-sid
# Twilio auth token from the Twilio dashboard (WhatsApp messages)
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM=+1234567890


# OpenAI API key from openai.com (for AI summaries and transcripts)
OPENAI_API_KEY=your-openai-key

# Internal microservice URLs (used by API gateway)
APPOINTMENTS_URL=http://appointments-service:3000
NOTES_URL=http://notes-service:3000
ANALYTICS_URL=http://analytics-service:3000
THERAPISTS_URL=http://therapists-service:3000
SETTINGS_URL=http://settings-service:3000

# API base URL used by the frontend
VITE_API_URL=http://localhost:3000

# SMTP server host (MailDev for local testing, used for password resets)
SMTP_HOST=maildev
# SMTP server port
SMTP_PORT=1025
# SMTP username (leave blank for MailDev)
SMTP_USER=
# SMTP password (leave blank for MailDev)
SMTP_PASS=

# WhatsApp sender phone number in E.164 format
WHATSAPP_FROM=whatsapp:+1234567890

# Public application URL
APP_URL=http://localhost:5173

# Database connection string for services
DATABASE_URL=postgres://postgres:postgres@postgres:5432/clinic

# WhatsApp API key from your provider
WHATSAPP_API_KEY=your-whatsapp-key
# SMTP connection URL
SMTP_URL=smtp://user:pass@localhost:1025
# Payment gateway API key
PAYMENT_GATEWAY_KEY=your-payment-key
# Stripe secret key
STRIPE_SECRET=your-stripe-secret

# WebSocket and Recording Configuration
# WebSocket CORS origin (should match FRONTEND_ORIGIN)
WS_CORS_ORIGIN=http://localhost:5173
# WebSocket transport methods
WS_TRANSPORTS=websocket,polling

# Recording File Storage
# Maximum file size for recordings in MB
MAX_RECORDING_SIZE=500
# Supported recording file formats
SUPPORTED_RECORDING_FORMATS=mp4,mov,avi,mp3,wav,m4a,webm
# Recording storage path (for local development)
RECORDING_STORAGE_PATH=./uploads/recordings
# Recording retention period in days
RECORDING_RETENTION_DAYS=365

# MinIO/S3 Configuration for Production
# MinIO root user (default for Docker)
MINIO_ROOT_USER=minio
# MinIO root password (default for Docker)
MINIO_ROOT_PASSWORD=minio123
# S3 bucket name for recordings
RECORDINGS_BUCKET=clinic-recordings
# S3 bucket name for transcripts
TRANSCRIPTS_BUCKET=clinic-transcripts
# S3 bucket name for summaries
SUMMARIES_BUCKET=clinic-summaries

# AI Service Configuration
# Enable AI-powered session summaries
ENABLE_AI_SUMMARIES=true
# Enable automatic transcript generation
ENABLE_TRANSCRIPTION=true
# AI model for summaries (gpt-4, gpt-3.5-turbo, etc.)
AI_SUMMARY_MODEL=gpt-4
# AI model for transcription (whisper-1)
AI_TRANSCRIPTION_MODEL=whisper-1

# Billing Service Configuration
# Israeli payment processors
TRANZILLA_API_KEY=your-tranzilla-api-key
CARDCOM_API_KEY=your-cardcom-api-key
# International payment processor
STRIPE_SECRET_KEY=your-stripe-secret-key
# Israeli Tax Authority integration
ITA_API_KEY=your-ita-api-key
ITA_API_URL=https://shaam.gov.il/api/v1
COMPANY_VAT_ID=123456789
# Frontend URL for payment links
FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development
