# PostgreSQL server host (Docker service name)
POSTGRES_HOST=postgres

# PostgreSQL server port
POSTGRES_PORT=5432

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password
POSTGRES_PASSWORD=postgres

# Name of the database
POSTGRES_DB=clinic

# Secret used for signing JWT tokens
JWT_SECRET=change-me

# NATS message broker URL
NATS_URL=nats://localhost:4222

# Endpoint for S3 or MinIO storage
S3_ENDPOINT=http://localhost:9000
# S3/MinIO access key (create in your storage provider)
S3_ACCESS_KEY=your-access-key
# S3/MinIO secret key (create in your storage provider)
S3_SECRET_KEY=your-secret-key

# Allowed CORS origin for backend APIs
FRONTEND_ORIGIN=http://localhost:5173
# Base URL of the API gateway
API_URL=http://localhost:3000

# Google OAuth client ID for the frontend
VITE_GOOGLE_CLIENT_ID=your-google-client-id
# Google OAuth client ID for the backend
GOOGLE_CLIENT_ID=your-google-client-id

# Email account username for SMTP
EMAIL_USER=your-email@example.com
# Email account password for SMTP
EMAIL_PASS=your-email-password

# Twilio account SID from the Twilio dashboard
TWILIO_ACCOUNT_SID=your-twilio-sid
# Twilio auth token from the Twilio dashboard
TWILIO_AUTH_TOKEN=your-twilio-token

# OpenAI API key from openai.com
OPENAI_API_KEY=your-openai-key

# Internal microservice URLs (used by API gateway)
APPOINTMENTS_URL=http://appointments-service:3000
NOTES_URL=http://notes-service:3000
ANALYTICS_URL=http://analytics-service:3000
THERAPISTS_URL=http://therapists-service:3000
SETTINGS_URL=http://settings-service:3000

# API base URL used by the frontend
VITE_API_URL=http://localhost:3000

# SMTP server host (MailDev for local testing)
SMTP_HOST=maildev
# SMTP server port
SMTP_PORT=1025
# SMTP username (leave blank for MailDev)
SMTP_USER=
# SMTP password (leave blank for MailDev)
SMTP_PASS=

# WhatsApp sender phone number in E.164 format
WHATSAPP_FROM=whatsapp:+1234567890

# Public application URL
APP_URL=http://localhost:5173

# Database connection string for services
DATABASE_URL=postgres://postgres:postgres@postgres:5432/clinic

# WhatsApp API key from your provider
WHATSAPP_API_KEY=your-whatsapp-key
# SMTP connection URL
SMTP_URL=smtp://user:pass@localhost:1025
# Payment gateway API key
PAYMENT_GATEWAY_KEY=your-payment-key
# Stripe secret key
STRIPE_SECRET=your-stripe-secret

