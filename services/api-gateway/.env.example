# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=clinic_admin
DB_LOGGING=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Admin Configuration
ADMIN_EMAIL=admin@clinic.com
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator

# Security Configuration
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=30m
SESSION_TIMEOUT=3600
MFA_ISSUER=Clinic Management System

# Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_WINDOW=1m
API_RATE_LIMIT_MAX_REQUESTS=60

# Backup Configuration
BACKUP_STORAGE_PATH=/var/backups/clinic
BACKUP_RETENTION_DAYS=90
BACKUP_ENCRYPTION_KEY=your-backup-encryption-key-32-chars

# Email Configuration (for notifications)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clinic.com

# Monitoring & Performance
METRICS_RETENTION_DAYS=90
PERFORMANCE_ALERT_THRESHOLD_CPU=80
PERFORMANCE_ALERT_THRESHOLD_MEMORY=85
PERFORMANCE_ALERT_THRESHOLD_RESPONSE_TIME=1000

# Compliance & Audit
AUDIT_RETENTION_DAYS=2555  # 7 years for healthcare compliance
COMPLIANCE_REPORT_SCHEDULE=0 0 1 * *  # Monthly on 1st at midnight
AUDIT_LOG_LEVEL=info

# API Management
API_KEY_EXPIRY_DAYS=365
API_KEY_ROTATION_DAYS=90
CLIENT_QUOTA_DEFAULT_DAILY=100000
CLIENT_QUOTA_DEFAULT_MONTHLY=3000000

# Cache Configuration
CACHE_TTL_DEFAULT=3600
CACHE_TTL_USER_SESSIONS=1800
CACHE_TTL_API_RESPONSES=300
CACHE_MAX_SIZE=2GB

# Load Balancer
LB_ALGORITHM=least_connections
LB_HEALTH_CHECK_INTERVAL=30
LB_HEALTH_CHECK_TIMEOUT=5
LB_HEALTH_CHECK_HEALTHY_THRESHOLD=2
LB_HEALTH_CHECK_UNHEALTHY_THRESHOLD=3

# Environment
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/clinic
LOG_MAX_FILES=30
LOG_MAX_SIZE=100m

# External Services
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

OPENAI_API_KEY=your-openai-api-key

# Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clinic-files

# NATS Configuration
NATS_URL=nats://localhost:4222
NATS_USER=
NATS_PASSWORD=

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key
ENCRYPTION_ALGORITHM=aes-256-gcm

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# CSP (Content Security Policy)
CSP_ENABLED=true
CSP_REPORT_ONLY=false

# Performance Monitoring
APM_ENABLED=true
APM_SAMPLE_RATE=0.1
APM_SERVICE_NAME=clinic-api-gateway

# Database Connection Pool
DB_CONNECTION_POOL_MIN=5
DB_CONNECTION_POOL_MAX=20
DB_CONNECTION_TIMEOUT=60000
DB_IDLE_TIMEOUT=300000

# Admin Console Features
ADMIN_CONSOLE_ENABLED=true
ADMIN_SETUP_ENABLED=true
ADMIN_MFA_REQUIRED=false
ADMIN_PASSWORD_EXPIRY_DAYS=90
ADMIN_SESSION_TIMEOUT=7200