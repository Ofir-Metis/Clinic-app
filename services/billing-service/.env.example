# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_NAME=clinic_billing
DB_LOGGING=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB_BILLING=1

# Service Configuration
NODE_ENV=development
PORT=3009
SERVICE_NAME=billing-service

# Israeli Tax Authority Integration
ITA_API_URL=https://shaam.gov.il/api/v1
ITA_API_KEY=your-ita-api-key
COMPANY_VAT_ID=123456789
ACCOUNTING_SOFTWARE_ID=CLINIC-001

# Payment Processing
TRANZILLA_API_KEY=your-tranzilla-key
TRANZILLA_TERMINAL_ID=your-terminal-id
CARDCOM_API_KEY=your-cardcom-key
STRIPE_SECRET_KEY=your-stripe-secret-key

# Notifications
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@clinic.com

# Twilio SMS
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+972501234567

# Frontend Configuration
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Security
JWT_SECRET=your-jwt-secret
ENCRYPTION_KEY=your-32-character-encryption-key

# Israeli Compliance
VAT_RATE=0.18
CTC_THRESHOLD_NIS=20000
COMPLIANCE_RETENTION_YEARS=7

# Billing Configuration
PLATFORM_COMMISSION_RATE=0.035
DEFAULT_PAYMENT_TERMS_DAYS=30
REMINDER_DAYS_BEFORE_DUE=7,3
SUSPENSION_DAYS_AFTER_DUE=7

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/clinic/billing-service