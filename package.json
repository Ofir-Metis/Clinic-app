    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "nats": "^2.15.1",
    "parse5": "^8.0.0",
    "pg": "^8.11.0",
    "ts-morph": "17.0.1",
    "undici-types": "^7.11.0"
  }
