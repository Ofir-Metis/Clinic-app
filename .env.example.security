# Security Configuration for Request Size Limits and Payload Validation

# Request Size Limits
MAX_BODY_SIZE=10mb                    # Maximum body size for API requests
MAX_FILE_SIZE=500mb                   # Maximum file size for uploads
MAX_FILES=10                          # Maximum number of files in single upload
MAX_URL_LENGTH=2048                   # Maximum URL length
MAX_HEADER_SIZE=8192                  # Maximum headers size in bytes

# Content Type Validation
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/gif,image/webp,video/mp4,video/mov,video/avi,audio/mp3,audio/wav,audio/m4a,audio/webm,application/pdf,text/plain"

# Payload Structure Limits
MAX_PAYLOAD_DEPTH=10                  # Maximum object nesting depth
MAX_ARRAY_LENGTH=1000                 # Maximum array length
MAX_STRING_LENGTH=100000              # Maximum string length (100KB)
MAX_FIELD_COUNT=1000                  # Maximum number of fields in object

# Rate Limiting (from previous implementation)
RATE_LIMIT_STRICT_TTL=900000          # 15 minutes for strict endpoints
RATE_LIMIT_STRICT_LIMIT=5             # 5 requests per 15 minutes
RATE_LIMIT_MODERATE_TTL=60000         # 1 minute for moderate endpoints
RATE_LIMIT_MODERATE_LIMIT=30          # 30 requests per minute
RATE_LIMIT_LENIENT_TTL=60000          # 1 minute for lenient endpoints
RATE_LIMIT_LENIENT_LIMIT=100          # 100 requests per minute

# Content Security
ENABLE_INPUT_SANITIZATION=true        # Enable automatic input sanitization
ENABLE_XSS_PROTECTION=true           # Enable XSS protection
ENABLE_SQL_INJECTION_PROTECTION=true # Enable SQL injection protection
ENABLE_PAYLOAD_VALIDATION=true       # Enable payload structure validation

# File Upload Security
UPLOAD_SCAN_ENABLED=false            # Enable virus scanning (requires external service)
UPLOAD_QUARANTINE_ENABLED=false     # Enable file quarantine
UPLOAD_MAX_FILENAME_LENGTH=255       # Maximum filename length
UPLOAD_BLOCKED_EXTENSIONS=".exe,.bat,.cmd,.com,.pif,.scr,.vbs,.js"

# API Security
API_TIMEOUT=30000                    # API request timeout in milliseconds
ENABLE_CORS_VALIDATION=true         # Enable CORS validation
ALLOWED_ORIGINS="http://localhost:5173,https://app.clinic-platform.com"
ENABLE_CSRF_PROTECTION=false        # Enable CSRF protection (set to true for production)

# CSRF Protection Settings
CSRF_TOKEN_LENGTH=32                 # CSRF token length in bytes (32 bytes = 256 bits)
CSRF_COOKIE_NAME="_csrf"            # Name of CSRF cookie
CSRF_TOKEN_EXPIRY=86400000          # CSRF token expiry in milliseconds (24 hours)
COOKIE_SECRET="your-cookie-secret-here"  # Secret for signing CSRF cookies (CHANGE IN PRODUCTION)

# Security Headers Configuration
CSP_POLICY=""                       # Custom Content Security Policy (leave empty for auto-generated)
CSP_REPORT_ONLY=""                  # CSP Report-Only policy for testing
CSP_REPORT_URI=""                   # URI for CSP violation reports
X_FRAME_OPTIONS="DENY"              # Frame options: DENY, SAMEORIGIN, or ALLOW-FROM
REFERRER_POLICY="strict-origin-when-cross-origin"  # Referrer policy
HSTS_MAX_AGE=31536000               # HSTS max age in seconds (1 year)
HSTS_INCLUDE_SUBDOMAINS=true        # Include subdomains in HSTS
HSTS_PRELOAD=true                   # Enable HSTS preload
SET_GENERIC_SERVER_HEADER=false     # Set generic server header to hide technology

# Session Management Configuration
SESSION_MAX_AGE=28800000            # Maximum session age in milliseconds (8 hours)
SESSION_INACTIVITY_TIMEOUT=1800000  # Inactivity timeout in milliseconds (30 minutes)
MAX_CONCURRENT_SESSIONS=3           # Maximum concurrent sessions per user
SESSION_SECRET_KEY="your-session-secret-key-change-in-production"  # Session signing key
ENABLE_DEVICE_TRACKING=true         # Enable device fingerprinting
REQUIRE_SECURE_TRANSPORT=true       # Require HTTPS for sessions
ENABLE_SESSION_ROTATION=true        # Enable automatic session rotation
SESSION_CLEANUP_INTERVAL=300000     # Session cleanup interval in milliseconds (5 minutes)

# Monitoring and Logging
LOG_REQUEST_SIZE=true                # Log request sizes for monitoring
LOG_VALIDATION_FAILURES=true        # Log validation failures
ALERT_ON_LARGE_REQUESTS=true        # Alert on unusually large requests
LARGE_REQUEST_THRESHOLD=50mb         # Threshold for large request alerts

# Backup Security (from previous implementation)
BACKUP_ENCRYPTION_ENABLED=true      # Enable backup encryption
BACKUP_RETENTION_DAYS=30             # Backup retention period
BACKUP_S3_BUCKET=""                  # S3 bucket for backup storage
BACKUP_COMPRESSION_LEVEL=6           # Compression level (1-9)

# Database Security (from previous implementation)
ENABLE_QUERY_LOGGING=false          # Enable SQL query logging (security risk if enabled)
MAX_QUERY_TIMEOUT=30000              # Maximum query timeout
ENABLE_QUERY_VALIDATION=true        # Enable SQL injection protection
MAX_RESULTS_PER_QUERY=1000           # Maximum results per database query

# APM and Monitoring (from previous implementation)
APM_ENABLED=true                     # Enable Application Performance Monitoring
APM_PROVIDER=datadog                 # APM provider (datadog, newrelic, appdynamics, opentelemetry)
ENABLE_ERROR_TRACKING=true           # Enable error tracking
ENABLE_PERFORMANCE_MONITORING=true  # Enable performance monitoring
ENABLE_BUSINESS_METRICS=true        # Enable custom business metrics

# Secrets Management (from previous implementation)
SECRETS_PROVIDER=aws                 # Secrets provider (aws, azure, env)
AWS_SECRET_NAME=clinic-app-secrets   # AWS Secrets Manager secret name
AWS_REGION=us-east-1                # AWS region
AZURE_KEYVAULT_URL=""               # Azure Key Vault URL (if using Azure)