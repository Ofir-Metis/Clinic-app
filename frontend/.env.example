# Clinic Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# Authentication
VITE_JWT_STORAGE_KEY=clinic_jwt_token

# Security Features
VITE_CSRF_ENABLED=false  # Enable CSRF protection (set to true for production)

# Google Integration
# Get this from: https://console.cloud.google.com/apis/credentials
# Format: 123456789-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
# Instructions: See README.md section "Google OAuth Setup"
VITE_GOOGLE_CLIENT_ID=your-google-client-id-from-console

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_RECORDINGS=true
VITE_ENABLE_AI_FEATURES=true

# File Uploads
VITE_MAX_FILE_SIZE=500  # MB
VITE_ALLOWED_FILE_TYPES=image/*,video/*,audio/*,application/pdf

# UI Configuration
VITE_THEME=wellness
VITE_DEFAULT_LANGUAGE=en

# Service URLs (Legacy - for backward compatibility)
THERAPIST_SERVICE_URL=http://localhost:4000
APPOINTMENTS_SERVICE_URL=http://localhost:4000
