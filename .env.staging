# Healthcare Platform - Staging Environment Configuration

# Environment
NODE_ENV=staging
ENVIRONMENT=staging

# API Configuration
API_GATEWAY_PORT=4001
FRONTEND_PORT=5174
BASE_URL=https://staging.clinic-app.com

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5433
POSTGRES_DB=clinic_staging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=${POSTGRES_STAGING_PASSWORD}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6380
REDIS_PASSWORD=${REDIS_STAGING_PASSWORD}

# Message Queue
NATS_URL=nats://nats:4223
NATS_MONITOR_PORT=8223

# Authentication & Security
JWT_SECRET=${JWT_STAGING_SECRET}
JWT_EXPIRES_IN=24h
SESSION_SECRET=${SESSION_STAGING_SECRET}
ENCRYPTION_KEY=${ENCRYPTION_STAGING_KEY}

# File Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9002
MINIO_ACCESS_KEY=${MINIO_STAGING_ACCESS_KEY}
MINIO_SECRET_KEY=${MINIO_STAGING_SECRET_KEY}
MINIO_BUCKET_NAME=clinic-staging

# External Services - Test/Staging Credentials
OPENAI_API_KEY=${OPENAI_STAGING_API_KEY}
TWILIO_ACCOUNT_SID=${TWILIO_STAGING_ACCOUNT_SID}
TWILIO_AUTH_TOKEN=${TWILIO_STAGING_AUTH_TOKEN}
TWILIO_PHONE_NUMBER=${TWILIO_STAGING_PHONE_NUMBER}

# Email Configuration (Staging)
SMTP_HOST=maildev
SMTP_PORT=1026
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="staging@clinic-app.com"

# Google Services (Staging)
GOOGLE_CLIENT_ID=${GOOGLE_STAGING_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_STAGING_CLIENT_SECRET}
GOOGLE_REDIRECT_URI=https://staging.clinic-app.com/auth/google/callback

# Payment Processing - Test Mode
STRIPE_SECRET_KEY=${STRIPE_TEST_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_TEST_WEBHOOK_SECRET}

# Israeli Payment Gateways - Test
TRANZILLA_TERMINAL=${TRANZILLA_TEST_TERMINAL}
TRANZILLA_USERNAME=${TRANZILLA_TEST_USERNAME}
TRANZILLA_PASSWORD=${TRANZILLA_TEST_PASSWORD}

CARDCOM_TERMINAL=${CARDCOM_TEST_TERMINAL}
CARDCOM_USERNAME=${CARDCOM_TEST_USERNAME}
CARDCOM_PASSWORD=${CARDCOM_TEST_PASSWORD}

# Search Engine
ELASTICSEARCH_URL=http://elasticsearch:9201
ELASTICSEARCH_PASSWORD=${ELASTICSEARCH_STAGING_PASSWORD}

# Monitoring & Logging
LOG_LEVEL=debug
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001
GRAFANA_PASSWORD=${GRAFANA_STAGING_PASSWORD}

# Frontend Environment Variables
VITE_API_URL=https://staging-api.clinic-app.com
VITE_WS_URL=wss://staging-api.clinic-app.com
VITE_ENVIRONMENT=staging
VITE_GOOGLE_ANALYTICS_ID=${GA_STAGING_ID}
VITE_SENTRY_DSN=${SENTRY_STAGING_DSN}

# CDN & Assets
CDN_S3_BUCKET=clinic-cdn-staging
CDN_CLOUDFRONT_DOMAIN=staging-cdn.clinic-app.com
CLOUDFRONT_DISTRIBUTION_ID=${CLOUDFRONT_STAGING_DISTRIBUTION_ID}

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_STAGING_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_STAGING_SECRET_ACCESS_KEY}

# Rate Limiting (More Permissive for Testing)
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW=300000

# HIPAA & Compliance (Staging)
HIPAA_AUDIT_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
DATA_ENCRYPTION_AT_REST=true
BACKUP_RETENTION_DAYS=30

# Container Registry
REGISTRY=ghcr.io
REPOSITORY=clinic-app
IMAGE_TAG=staging-latest

# Deployment
DEPLOYMENT_TIMEOUT=600
HEALTH_CHECK_TIMEOUT=120
RESTART_POLICY=on-failure
RESTART_ATTEMPTS=3

# Feature Flags (Staging)
FEATURE_AI_ANALYSIS=true
FEATURE_GOOGLE_INTEGRATION=true
FEATURE_ADVANCED_BILLING=true
FEATURE_MULTI_LANGUAGE=true
FEATURE_MOBILE_APP=false

# Testing Configuration
TEST_DATABASE_URL=postgresql://postgres:${POSTGRES_STAGING_PASSWORD}@postgres:5433/clinic_staging_test
E2E_BASE_URL=https://staging.clinic-app.com
PLAYWRIGHT_BROWSERS=chromium,firefox

# Development Tools (Staging Only)
MAILDEV_SMTP_PORT=1026
MAILDEV_WEB_PORT=1081
SWAGGER_ENABLED=true
DEBUG_MODE=true