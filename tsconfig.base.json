{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2019",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "paths": {
      "@clinic/common/*": ["libs/common/dist/*"],
      "@clinic/common": ["libs/common/dist"]
    },
    "moduleResolution": "node",
    "esModuleInterop": true,
    "useDefineForClassFields": false
  }
}
